# === GitHub API ===
# Token d'accès personnel (classic) avec scope "repo" (obligatoire)
# Générer ici : https://github.com/settings/tokens
GITHUB_TOKEN="votre_github_token_ici"

# === Google Gemini API ===
# Clé API Gemini pour l'analyse et l'Architecte
# Générer ici : https://aistudio.google.com/apikey
GEMINI_API_KEY="votre_cle_gemini_ici"

# === NextAuth (Authentification) ===
# URL de base de l'application (http://localhost:3000 en dev)
NEXTAUTH_URL="http://localhost:3000"
# Clé secrète pour chiffrer les sessions (générer via 'openssl rand -base64 32')
NEXTAUTH_SECRET="une_cle_secrete_tres_longue_et_aleatoire"

# === Base de Données (SQLite / Prisma) ===
# Chemin vers le fichier SQLite local
DATABASE_URL="file:./prisma/dev.db"
